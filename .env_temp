# GPT-SoVITS 数据预处理 — 环境变量配置
# 复制此文件为 .env 并填入你的 API Key:
#   cp .env_temp .env
#
# .env 已加入 .gitignore，不会被提交到仓库。

# 阿里云 DashScope (qwen3-asr-flash)
# 获取地址: https://bailian.console.aliyun.com/?tab=api-key
DASHSCOPE_API_KEY=sk-xxx

# DeepSeek (可选，用于文本情感二次校验)
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxx
